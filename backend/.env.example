# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional model overrides (defaults shown).
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# Optional: live flight + hotel prices via Amadeus Self-Service (free tier).
# Register a free Self-Service app at https://developers.amadeus.com to get keys.
# Without these, Atlas falls back to built-in planning estimates.
# AMADEUS_CLIENT_ID=your_amadeus_api_key
# AMADEUS_CLIENT_SECRET=your_amadeus_api_secret
# AMADEUS_HOSTNAME=test          # "test" (free test data) or "production"

# Optional: override the static USD->INR fallback rate (live FX used when available).
# USD_TO_INR=83
