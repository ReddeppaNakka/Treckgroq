# Frontend environment (Vite). Copy to .env and fill in.

# Backend base URL for a deployed build (dev uses the Vite proxy, leave blank).
# VITE_API_BASE=

# Optional: high-quality destination photos via Unsplash.
# Create a free app at https://unsplash.com/developers and paste the Access Key.
# Without it, Atlas falls back to a keyless image source.
# VITE_UNSPLASH_KEY=your_unsplash_access_key
